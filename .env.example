# Server Configuration
PORT=5000
NODE_ENV=development

# Groq API Key - Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Finnhub API Key (Recommended - for stock news)
# Get a free key at https://finnhub.io/register
# Free tier: 60 API calls/minute
FINNHUB_API_KEY=your_finnhub_api_key_here

# HuggingFace API Key (Optional - for FinBERT sentiment analysis)
# Get a free key at https://huggingface.co/settings/tokens
# Without this, the app will use rate-limited inference or fallback to keyword-based sentiment
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Database (SQLite for dev - no configuration needed)
# The app will automatically create dev.db file

# Stock Discovery Configuration (Optional)
# USE_DYNAMIC_DISCOVERY=true  # Set to true to discover trending stocks dynamically
# LARGE_CAP_COUNT=3            # Number of large cap stocks (>$200B)
# MID_CAP_COUNT=3              # Number of mid cap stocks ($10B-$200B)
# SMALL_CAP_COUNT=3            # Number of small cap stocks (<$10B)
